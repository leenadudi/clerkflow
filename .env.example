# Neon Postgres — https://neon.tech
DATABASE_URL=

# Demo database — required for demo mode; if unset, demo requests throw instead
# of silently falling through to production data
DATABASE_URL_DEMO=

# Clerk staff auth — https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/app/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/app/sign-up

# Password for /internal prospecting (required in production)
INTERNAL_PASSWORD=

# Legacy alias — still works if INTERNAL_PASSWORD is unset
INTERNAL_SECRET=

# Resend — https://resend.com (verify clerkflow.software domain first)
RESEND_API_KEY=
FROM_EMAIL=leena@clerkflow.software

# Groq — https://console.groq.com (required for meeting transcription)
GROQ_API_KEY=

# Cron secret — must match x-cron-secret header sent by cron-job.org
# If unset, /api/email/poll rejects all requests
CRON_SECRET=

# Google AI (Gemini) — used by @google/genai for minutes generation and import
GOOGLE_AI_API_KEY=

# Google AI (Gemini) — used by @ai-sdk/google for the Clerkie AI assistant
# Can be the same key as GOOGLE_AI_API_KEY; get one at aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Cloudflare R2 (optional — file uploads, Phase 2)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
